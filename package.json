{
  "name": "equinox-orbit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "npm run test:d1 && npm run orbit:test && npm run orbit:validate && npm run og:generate && astro build && npm run site:test && npm run browser:test",
    "worker:build": "astro build --config astro.worker.config.mjs",
    "d1:migrate:local": "wrangler d1 migrations apply orbit-v6-local --local",
    "test:d1": "tsx --test scripts/orbit-d1-tests.ts",
    "v6:check": "npm run test:d1 && npm run check && npm run worker:build",
    "preview": "astro preview",
    "check": "npm run orbit:validate && astro check",
    "orbit:validate": "node scripts/orbit-validate.mjs",
    "orbit:index": "node scripts/orbit-index.mjs",
    "orbit:test": "node scripts/orbit-content-tests.mjs && node scripts/orbit-cli-tests.mjs",
    "site:test": "node scripts/orbit-site-tests.mjs",
    "browser:test": "node scripts/orbit-browser-tests.mjs",
    "og:generate": "node scripts/orbit-og-images.mjs",
    "orbit": "node scripts/orbit-cli.mjs",
    "orbit:post": "node scripts/orbit-post.mjs",
    "orbit:publish": "node scripts/orbit-publish.mjs"
  },
  "dependencies": {
    "@astrojs/cloudflare": "14.1.3",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "latest",
    "astro": "latest",
    "gray-matter": "^4.0.3",
    "uuid": "14.0.1"
  },
  "devDependencies": {
    "@astrojs/check": "latest",
    "@cloudflare/workers-types": "5.20260715.1",
    "playwright-core": "^1.61.1",
    "sharp": "^0.35.3",
    "tsx": "4.23.1",
    "typescript": "latest",
    "wrangler": "4.111.0"
  }
}
