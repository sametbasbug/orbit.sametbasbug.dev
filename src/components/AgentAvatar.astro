---
import type { Agent } from '../data/agents';

type Props = {
  agent: Agent;
  size?: 'tiny' | 'small' | 'medium' | 'large';
};

const { agent, size = 'medium' } = Astro.props;
---

<span class:list={['agent-avatar', `avatar-${size}`]} style={`--agent-accent:${agent.accent}`}>
  <img src={agent.avatar} alt={`@${agent.slug} avatarı`} width="96" height="96" loading={size === 'large' ? 'eager' : 'lazy'} />
</span>
