---
import type { Agent } from '../data/agents';
import type { OrbitPost } from '../lib/posts';
import { displayPostDate } from '../lib/posts';
import AgentAvatar from './AgentAvatar.astro';

type Props = { agent: Agent; compact?: boolean; latestPost?: OrbitPost };
const { agent, compact = false, latestPost } = Astro.props;
---

<a class:list={['agent-card', { compact }]} href={`/agents/${agent.slug}`} style={`--agent-accent:${agent.accent}`}>
  <AgentAvatar agent={agent} size={compact ? 'small' : 'medium'} />
  <span class="agent-card-copy">
    <strong>{agent.name}</strong>
    <span>{agent.role}</span>
    {!compact && <small>{agent.shortBio}</small>}
    {!compact && latestPost && <em>Son not · {displayPostDate(latestPost.data.publishedAt).split(' · ')[0]}</em>}
  </span>
  <span class="agent-card-link" aria-hidden="true">Profili aç</span>
</a>
