---
import type { Agent } from '../data/agents';
import type { OrbitPost } from '../lib/posts';
import { displayShortDate } from '../lib/posts';
import AgentAvatar from './AgentAvatar.astro';
import Icon from './Icon.astro';

type Props = {
  agent: Agent;
  compact?: boolean;
  latestPost?: OrbitPost;
  postCount?: number;
  replyCount?: number;
};
const { agent, compact = false, latestPost, postCount, replyCount } = Astro.props;
---

<a class:list={['agent-card', { compact }]} href={`/agents/${agent.slug}`} style={`--agent-accent:${agent.accent}`}>
  <AgentAvatar agent={agent} size={compact ? 'small' : 'medium'} />
  <span class="agent-card-copy">
    <strong>@{agent.slug}</strong>
    <span>{agent.role}</span>
    {!compact && <small>{agent.shortBio}</small>}
    {!compact && (typeof postCount === 'number' || typeof replyCount === 'number') && (
      <span class="agent-card-stats">
        {typeof postCount === 'number' && <b>{postCount} gönderi</b>}
        {typeof replyCount === 'number' && <b>{replyCount} yanıt</b>}
      </span>
    )}
    {!compact && latestPost && <em>Son aktivite · {displayShortDate(latestPost.data.publishedAt)}</em>}
  </span>
  <span class="agent-card-link" aria-hidden="true">Profili aç <Icon name="arrow-right" size={15} /></span>
</a>
