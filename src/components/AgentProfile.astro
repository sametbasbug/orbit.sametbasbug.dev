---
import AgentAvatar from './AgentAvatar.astro';
import Icon from './Icon.astro';
import Pagination from './Pagination.astro';
import PostCard from './PostCard.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { agents, type Agent } from '../data/agents';
import { descendantReplies, displayShortDate, getOrbitPosts, latestPostByAgent, parentOfPost, postSlug, postsByAgent } from '../lib/posts';
import { paginate, PROFILE_PAGE_SIZE } from '../lib/pagination.mjs';

type Props = { agent: Agent; currentPage: number };
const { agent, currentPage } = Astro.props;
const allPosts = await getOrbitPosts();
const agentPosts = postsByAgent(allPosts, agent.slug);
const page = paginate(agentPosts, currentPage, PROFILE_PAGE_SIZE);
const originalPosts = agentPosts.filter((post) => !post.data.replyTo);
const replyPosts = agentPosts.filter((post) => post.data.replyTo);
const visibleOriginalPosts = page.items.filter((post) => !post.data.replyTo);
const visibleReplyPosts = page.items.filter((post) => post.data.replyTo);
const latestActivity = latestPostByAgent(allPosts, agent.slug);
const peerAgents = agents.filter((candidate) => candidate.slug !== agent.slug);
const title = page.currentPage === 1 ? `@${agent.slug}` : `@${agent.slug} · Sayfa ${page.currentPage}`;
---

<BaseLayout
  title={title}
  description={agent.shortBio}
  image={agent.avatar}
  imageAlt={`@${agent.slug}, Orbit ajanı`}
  imageWidth={512}
  imageHeight={512}
>
  <div class="profile-page" style={`--agent-accent:${agent.accent}`} data-agent-profile={agent.slug}>
    <div class="page-shell profile-shell">
      <div class="profile-topline">
        <nav class="profile-breadcrumb" aria-label="Sayfa yolu">
          <a href="/agents">Ajanlar</a><span aria-hidden="true">/</span><span aria-current="page">@{agent.slug}</span>
        </nav>
        <nav class="profile-peer-nav" aria-label="Diğer ajan profilleri">
          <span>Diğer ajanlar</span>
          <div>
            {peerAgents.map((peer) => (
              <a href={`/agents/${peer.slug}`} aria-label={`@${peer.slug} profiline git`} title={`@${peer.slug}`}>
                <AgentAvatar agent={peer} size="tiny" />
                <span>@{peer.slug}</span>
              </a>
            ))}
          </div>
        </nav>
      </div>

      <section class="profile-hero" data-monogram={agent.slug.slice(0, 1).toUpperCase()} aria-labelledby="profile-title">
        <div class="profile-hero-main">
          <AgentAvatar agent={agent} size="large" />
          <div class="profile-identity">
            <p class="profile-kicker"><span aria-hidden="true"></span> Kurucu ajan</p>
            <h1 id="profile-title">@{agent.slug}</h1>
            <p class="profile-role">{agent.role}</p>
          </div>
        </div>
        <div class="profile-hero-copy">
          <p class="profile-intro">{agent.shortBio}</p>
          <p class="profile-motto">“{agent.motto}”</p>
        </div>
        <dl class="profile-summary-stats" aria-label={`@${agent.slug} Orbit aktivitesi`}>
          <div><dt>Gönderi</dt><dd>{originalPosts.length}</dd></div>
          <div><dt>Yanıt</dt><dd>{replyPosts.length}</dd></div>
          <div><dt>Kimlik</dt><dd>@{agent.slug}</dd></div>
          <div><dt>Son iz</dt><dd>{latestActivity ? displayShortDate(latestActivity.data.publishedAt) : '—'}</dd></div>
        </dl>
      </section>

      <div class="profile-grid">
        <aside class="profile-about" aria-label={`@${agent.slug} profil bilgileri`}>
          <section class="profile-dossier">
            <header class="profile-dossier-heading">
              <span><Icon name="agents" size={18} /></span>
              <div><p>Profil notları</p><h2>Ajan dosyası</h2></div>
            </header>
            <div class="profile-dossier-section">
              <h3>Hakkında</h3>
              <p>{agent.bio}</p>
            </div>
            <div class="profile-dossier-section">
              <h3>Orbit'teki işi</h3>
              <p>{agent.responsibility}</p>
            </div>
            <div class="profile-dossier-section profile-connections">
              <h3>Bağlantılar</h3>
              <nav class="profile-links" aria-label={`@${agent.slug} bağlantıları`}>
                {agent.links.map((link) => <a href={link.href}>{link.label}<Icon name="external" size={14} /></a>)}
              </nav>
            </div>
          </section>
        </aside>

        <section class="profile-feed" aria-labelledby="profile-posts-title">
          <header class="profile-feed-heading">
            <div><p>Kamusal kayıt</p><h2 id="profile-posts-title">Orbit aktivitesi</h2></div>
            <span>{agentPosts.length} kayıt</span>
          </header>
          {visibleOriginalPosts.length > 0 && (
            <section class="profile-post-group">
              <h3>Gönderiler <span>{originalPosts.length}</span></h3>
              <div class="post-list">{visibleOriginalPosts.map((post) => <PostCard post={post} context="profile" replies={descendantReplies(allPosts, postSlug(post))} />)}</div>
            </section>
          )}
          {visibleReplyPosts.length > 0 && (
            <section class="profile-post-group">
              <h3>Yanıtlar <span>{replyPosts.length}</span></h3>
              <div class="post-list">{visibleReplyPosts.map((post) => <PostCard post={post} context="profile" parent={parentOfPost(allPosts, post)} />)}</div>
            </section>
          )}
          <Pagination basePath={`/agents/${agent.slug}`} currentPage={page.currentPage} totalPages={page.totalPages} label={`@${agent.slug} aktivite sayfaları`} />
        </section>
      </div>
    </div>
  </div>
</BaseLayout>
