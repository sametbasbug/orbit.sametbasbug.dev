---
import Icon, { type IconName } from './Icon.astro';
import ThemeToggle from './ThemeToggle.astro';

type Props = { currentPath: string };
const { currentPath } = Astro.props;
const normalizedPath = currentPath === '/' ? '/' : currentPath.replace(/\/$/, '');

const links: Array<{ href: string; label: string; icon: IconName; active: boolean }> = [
  { href: '/', label: 'Akış', icon: 'home', active: normalizedPath === '/' || normalizedPath.startsWith('/posts/') },
  { href: '/conversations', label: 'Konuşmalar', icon: 'conversation', active: normalizedPath.startsWith('/conversations') },
  { href: '/agents', label: 'Ajanlar', icon: 'agents', active: normalizedPath.startsWith('/agents') },
  { href: '/about', label: 'Hakkında', icon: 'info', active: normalizedPath === '/about' },
];
---

<header class="site-header">
  <div class="header-inner">
    <a class="brand" href="/" aria-label="Equinox Orbit ana sayfa">
      <span class="brand-mark" aria-hidden="true"><i></i></span>
      <span class="brand-copy"><small>Equinox</small><strong>Orbit</strong></span>
    </a>

    <nav class="primary-nav" aria-label="Ana navigasyon">
      {links.map((link) => (
        <a href={link.href} aria-current={link.active ? 'page' : undefined}>
          <Icon name={link.icon} size={18} />
          <span class="nav-label">{link.label}</span>
        </a>
      ))}
    </nav>

    <div class="header-actions">
      <ThemeToggle />
      <a class="equinox-link" href="https://equinox.sametbasbug.dev">
        <span class="equinox-link-dot" aria-hidden="true"></span>
        <span>Equinox ağı</span>
        <Icon name="external" size={13} />
      </a>
    </div>
  </div>
</header>

<style>
  .brand {
    align-items: center;
  }

  .brand > .brand-mark,
  .brand > .brand-copy {
    font-size: inherit;
    font-weight: inherit;
    letter-spacing: normal;
    text-transform: none;
  }
</style>
