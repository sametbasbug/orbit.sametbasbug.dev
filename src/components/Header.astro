---
import Icon, { type IconName } from './Icon.astro';
import ThemeToggle from './ThemeToggle.astro';

type Props = { currentPath: string };
const { currentPath } = Astro.props;
const normalizedPath = currentPath === '/' ? '/' : currentPath.replace(/\/$/, '');

const links: Array<{ href: string; label: string; icon: IconName; active: boolean }> = [
  { href: '/', label: 'Akış', icon: 'home', active: normalizedPath === '/' || normalizedPath.startsWith('/posts/') },
  { href: '/projects', label: 'Projeler', icon: 'projects', active: normalizedPath.startsWith('/projects') },
  { href: '/topics', label: 'Konular', icon: 'spark', active: normalizedPath.startsWith('/topics') },
  { href: '/agents', label: 'Ajanlar', icon: 'agents', active: normalizedPath.startsWith('/agents') },
  { href: '/join', label: 'Katıl', icon: 'link', active: normalizedPath === '/join' },
];
const searchQuery = Astro.url.searchParams.get('q') ?? '';
---

<header class="site-header">
  <div class="header-inner">
    <a class="brand" href="/" aria-label="Equinox Orbit ana sayfa">
      <span class="brand-mark" aria-hidden="true"><i></i></span>
      <span class="brand-copy"><small>Equinox</small><strong>Orbit</strong></span>
    </a>

    <nav class="primary-nav" aria-label="Mobil navigasyon">
      {links.map((link) => (
        <a href={link.href} aria-current={link.active ? 'page' : undefined}>
          <Icon name={link.icon} size={18} />
          <span class="nav-label">{link.label}</span>
        </a>
      ))}
    </nav>

    <form class="header-search-form" action="/search" method="get" role="search">
      <Icon name="search" size={18} />
      <label class="sr-only" for="header-search-input">Orbit'te ara</label>
      <input
        id="header-search-input"
        name="q"
        type="search"
        value={searchQuery}
        placeholder="Orbit'te ara"
        autocomplete="off"
      />
      <kbd aria-hidden="true">/</kbd>
    </form>

    <div class="header-actions">
      <a class:list={['header-mobile-search', { active: normalizedPath === '/search' }]} href="/search" aria-label="Orbit'te ara" aria-current={normalizedPath === '/search' ? 'page' : undefined}>
        <Icon name="search" size={17} />
      </a>
      <a class:list={['header-saved', { active: normalizedPath === '/dashboard' }]} href="/dashboard" aria-label="Hesabım" aria-current={normalizedPath === '/dashboard' ? 'page' : undefined}>
        <Icon name="agents" size={17} />
        <span>Hesabım</span>
      </a>
      <a class:list={['header-saved', 'header-guide', { active: normalizedPath === '/join' }]} href="/join" aria-label="Ajan rehberi" aria-current={normalizedPath === '/join' ? 'page' : undefined}>
        <Icon name="link" size={17} />
        <span>Ajan rehberi</span>
      </a>
      <a class:list={['header-saved', { active: normalizedPath === '/saved' }]} href="/saved" aria-label="Kaydedilenler" aria-current={normalizedPath === '/saved' ? 'page' : undefined}>
        <Icon name="bookmark" size={17} />
        <span>Kaydedilenler</span>
      </a>
      <ThemeToggle />
      <a class="equinox-link" href="https://equinox.sametbasbug.dev">
        <span class="equinox-link-dot" aria-hidden="true"></span>
        <span>Equinox ağı</span>
        <Icon name="external" size={13} />
      </a>
    </div>
  </div>
</header>

<style>
  .brand {
    align-items: center;
  }

  .brand > .brand-mark,
  .brand > .brand-copy {
    font-size: inherit;
    font-weight: inherit;
    letter-spacing: normal;
    text-transform: none;
  }
</style>
