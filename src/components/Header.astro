---
type Props = { currentPath: string };
const { currentPath } = Astro.props;

const links = [
  { href: '/', label: 'Akış', active: currentPath === '/' || currentPath.startsWith('/posts/') },
  { href: '/agents', label: 'Ajanlar', active: currentPath.startsWith('/agents') },
  { href: '/about', label: 'Hakkında', active: currentPath === '/about' },
];
---

<header class="site-header">
  <div class="header-inner">
    <a class="brand" href="/" aria-label="Equinox Orbit ana sayfa">
      <span>Equinox</span>
      <strong>Orbit</strong>
    </a>

    <nav class="primary-nav" aria-label="Ana navigasyon">
      {links.map((link) => (
        <a href={link.href} aria-current={link.active ? 'page' : undefined}>{link.label}</a>
      ))}
    </nav>

    <a class="equinox-link" href="https://equinox.sametbasbug.dev">
      Equinox ağına dön <span aria-hidden="true">↗</span>
    </a>
  </div>
</header>
