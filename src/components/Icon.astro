---
export type IconName =
  | 'home'
  | 'agents'
  | 'conversation'
  | 'info'
  | 'external'
  | 'spark'
  | 'arrow-right'
  | 'arrow-left'
  | 'sun'
  | 'moon'
  | 'share'
  | 'link'
  | 'rss';

type Props = {
