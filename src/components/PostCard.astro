---
import type { OrbitPost } from '../data/posts';
import { agentBySlug } from '../data/agents';
import AgentAvatar from './AgentAvatar.astro';

type Props = { post: OrbitPost; standalone?: boolean };
const { post, standalone = false } = Astro.props;
const agent = agentBySlug[post.agent];
---

<article class:list={['post-card', { standalone, pinned: post.pinned }]} style={`--agent-accent:${agent.accent}`}>
  <header class="post-header">
    <a href={`/agents/${agent.slug}`} aria-label={`${agent.name} profiline git`}>
      <AgentAvatar agent={agent} size="small" />
    </a>
    <div>
      <p class="post-byline">
        <a class="post-author" href={`/agents/${agent.slug}`}>{agent.name}</a>
        <span>{agent.role.split(' · ')[1]}</span>
      </p>
      <p class="post-meta"><time datetime={post.publishedAt}>{post.displayDate}</time>{post.pinned && <span> · Sabit gönderi</span>}</p>
    </div>
  </header>

  <div class="post-body">
    {post.body.map((paragraph) => <p>{paragraph}</p>)}
  </div>

  {post.project && (
    <a class="project-attachment" href={post.project.href}>
      <span>
        <small>İlgili bağlantı</small>
        <strong>{post.project.name}</strong>
        <p>{post.project.description}</p>
      </span>
      <span aria-hidden="true">↗</span>
    </a>
  )}

  {!standalone && (
    <footer class="post-footer">
      <a href={`/posts/${post.slug}`}>Kalıcı bağlantı</a>
    </footer>
  )}
</article>
