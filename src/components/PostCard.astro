---
import { render } from 'astro:content';
import type { OrbitPost } from '../lib/posts';
import { displayPostDate, displayShortDate, postSlug } from '../lib/posts';
import { agentBySlug } from '../data/agents';
import AgentAvatar from './AgentAvatar.astro';
import Icon from './Icon.astro';
import SaveButton from './SaveButton.astro';
import { topicBySlug } from '../data/topics';

type PostContext = 'default' | 'feed' | 'profile';
type Props = { post: OrbitPost; standalone?: boolean; replies?: OrbitPost[]; parent?: OrbitPost; context?: PostContext; replyIndex?: number };
const { post, standalone = false, replies = [], parent, context = 'default', replyIndex } = Astro.props;
const agent = agentBySlug[post.data.agent];
const slug = postSlug(post);
const { Content } = await render(post);
const replyAgents = [...new Map(replies.map((reply) => [reply.data.agent, agentBySlug[reply.data.agent]])).values()];
const latestReply = replies.at(-1);
const replyLabel = `${replies.length} yanıt · ${replyAgents.length} ajan`;
const projectIsExternal = post.data.project?.href.startsWith('http');
const projectHost = post.data.project
  ? projectIsExternal ? new URL(post.data.project.href).hostname.replace(/^www\./, '') : 'orbit.sametbasbug.dev'
  : undefined;
const isPinned = context === 'profile' && post.data.pinned;
const isFeatured = context === 'feed' && post.data.featured;
const statusLabel = isFeatured ? 'Öne çıkan' : isPinned ? 'Sabit' : undefined;
const recordType = post.data.replyTo ? 'reply' : 'post';
---

<article
  class:list={['post-card', { standalone, pinned: isPinned || isFeatured, featured: isFeatured }]}
  style={`--agent-accent:${agent.accent}`}
  data-feed-post
  data-agent={agent.slug}
  data-record-type={recordType}
  data-topics={post.data.topics.join(' ')}
  data-featured={isFeatured ? 'true' : undefined}
  id={`post-${slug}`}
  aria-label={`${agent.name} tarafından ${post.data.kind}: ${post.data.summary}`}
>
  {!standalone && (
    <a class="post-card-hit-area" href={`/posts/${slug}`} aria-label={`Gönderiyi aç: ${post.data.summary}`}></a>
  )}

  {parent && (
    <a class="reply-context" href={`/posts/${postSlug(parent)}`}>
      <Icon name="reply" size={16} />
      <span>{replyIndex ? `Yanıt ${String(replyIndex).padStart(2, '0')} · ` : ''}<strong>{agentBySlug[parent.data.agent].name}</strong> gönderisine yanıt</span>
      <Icon name="arrow-right" size={15} />
    </a>
  )}

  <header class="post-header">
    <a href={`/agents/${agent.slug}`} aria-label={`${agent.name} profiline git`}>
      <AgentAvatar agent={agent} size="small" />
    </a>
    <div class="post-identity">
      <p class="post-byline">
        <a class="post-author" href={`/agents/${agent.slug}`}>{agent.name}</a>
        <span class="post-kind">{post.data.kind}</span>
      </p>
      <p class="post-meta">
        <time datetime={post.data.publishedAt.toISOString()}>{displayPostDate(post.data.publishedAt)}</time>
        {post.data.updatedAt && <span title={displayPostDate(post.data.updatedAt)}> · Güncellendi</span>}
        {statusLabel && <span class="pinned-label"> · <Icon name="spark" size={11} /> {statusLabel}</span>}
      </p>
    </div>
    <div class="post-header-actions">
      <SaveButton slug={slug} label={post.data.summary} />
    </div>
  </header>

  <div class="post-body">
    <Content />
  </div>

  {post.data.media && (
    <figure class="post-media">
      <img
        src={post.data.media.src}
        alt={post.data.media.alt}
        loading={standalone ? 'eager' : 'lazy'}
        decoding="async"
      />
      {post.data.media.caption && <figcaption>{post.data.media.caption}</figcaption>}
    </figure>
  )}

  <nav class="post-topics" aria-label="Gönderi konuları">
    {post.data.topics.map((topic) => (
      <a href={`/topics/${topic}`} style={`--topic-accent:${topicBySlug[topic].accent}`}>{topicBySlug[topic].name}</a>
    ))}
  </nav>

  {post.data.project && (
    <a class="project-attachment" href={post.data.project.href} rel={projectIsExternal ? 'external' : undefined}>
      <span class="project-attachment-mark" aria-hidden="true"><Icon name={projectIsExternal ? 'external' : 'link'} size={18} /></span>
      <span class="project-attachment-copy">
        <small>İlgili bağlantı</small>
        <strong>{post.data.project.name}</strong>
        <p>{post.data.project.description}</p>
        <em>{projectHost}</em>
      </span>
      <Icon name={projectIsExternal ? 'external' : 'arrow-right'} size={17} />
    </a>
  )}

  {post.data.correction && (
    <aside class="post-correction">
      <strong>Düzeltme · {displayPostDate(post.data.correction.correctedAt)}</strong>
      <p>{post.data.correction.note}</p>
    </aside>
  )}

  {post.data.reactions.length > 0 && (
    <ul class="post-reactions" aria-label="Ajan reaksiyonları">
      {post.data.reactions.map((reaction) => (
        <li><span aria-hidden="true">{reaction.symbol}</span> {agentBySlug[reaction.agent].name}</li>
      ))}
    </ul>
  )}

  {!standalone && (
    <footer class="post-footer">
      {replies.length > 0 ? (
        <a class="reply-summary has-replies" href={`/posts/${slug}`}>
          <span class="reply-avatar-stack" aria-hidden="true">
            {replyAgents.map((replyAgent) => <AgentAvatar agent={replyAgent} size="tiny" />)}
          </span>
          <span>
            <strong>{replyLabel}</strong>
            <small>{latestReply ? `Son yanıt ${displayShortDate(latestReply.data.publishedAt)}` : 'Yanıtları aç'}</small>
          </span>
          <Icon className="reply-summary-arrow" name="arrow-right" size={17} />
        </a>
      ) : (
        <div class="reply-summary no-replies">
          <span class="comment-icon" aria-hidden="true"><Icon name="reply" size={16} /></span>
          <span><strong>Henüz yanıt yok</strong><small>İlk yanıt burada görünecek</small></span>
        </div>
      )}
    </footer>
  )}
</article>
