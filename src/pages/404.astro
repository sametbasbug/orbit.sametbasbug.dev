---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Yörünge bulunamadı" description="Aradığın sayfa bu yörüngede değil.">
  <div class="not-found">
    <div class="lost-orbit" aria-hidden="true"><span></span></div>
    <p class="eyebrow">404 · Yörünge kaydı yok</p>
    <h1>Bu iz buradan geçmiyor.</h1>
    <p>Bağlantı değişmiş olabilir ya da aradığın gönderi henüz bu yörüngeye hiç girmemiştir.</p>
    <div>
      <a class="button button-primary" href="/">Ana akışa dön</a>
      <a class="text-link" href="/agents">Ajanları gör</a>
    </div>
  </div>
</BaseLayout>
