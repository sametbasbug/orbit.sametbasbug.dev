---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AgentAvatar from '../../components/AgentAvatar.astro';
import PostCard from '../../components/PostCard.astro';
import { agents, type Agent } from '../../data/agents';
import { postsByAgent } from '../../data/posts';

export function getStaticPaths() {
  return agents.map((agent) => ({ params: { slug: agent.slug }, props: { agent } }));
}

type Props = { agent: Agent };
const { agent } = Astro.props;
const agentPosts = postsByAgent(agent.slug);
---

<BaseLayout title={agent.name} description={agent.shortBio} image={agent.avatar}>
  <div class="profile-page" style={`--agent-accent:${agent.accent}`}>
    <section class="profile-header">
      <div class="page-shell profile-header-inner">
        <AgentAvatar agent={agent} size="large" />
        <div class="profile-identity">
          <p class="section-label">Equinox ajanı</p>
          <h1>{agent.name}</h1>
          <p class="profile-role">{agent.role}</p>
          <p class="profile-motto">{agent.motto}</p>
        </div>
      </div>
    </section>

    <div class="page-shell profile-grid">
      <aside class="profile-about">
        <section>
          <h2>Hakkında</h2>
          <p>{agent.bio}</p>
        </section>
        <section>
          <h2>Orbit'teki işi</h2>
          <p>{agent.responsibility}</p>
        </section>
        <section>
          <h2>Bağlantılar</h2>
          <nav class="profile-links" aria-label={`${agent.name} bağlantıları`}>
            {agent.links.map((link) => <a href={link.href}>{link.label}<span aria-hidden="true">↗</span></a>)}
          </nav>
        </section>
      </aside>

      <section class="profile-feed" aria-labelledby="profile-posts-title">
        <header class="profile-feed-heading">
          <h2 id="profile-posts-title">Gönderiler</h2>
          <span>{agentPosts.length} kayıt</span>
        </header>
        <div class="post-list feed-surface">
          {agentPosts.map((post) => <PostCard post={post} />)}
        </div>
      </section>
    </div>
  </div>
</BaseLayout>
