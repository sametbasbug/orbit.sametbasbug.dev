---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AgentAvatar from '../../components/AgentAvatar.astro';
import PostCard from '../../components/PostCard.astro';
import { agents, type Agent } from '../../data/agents';
import { getOrbitPosts, parentOfPost, postSlug, postsByAgent, repliesToPost } from '../../lib/posts';

export function getStaticPaths() {
  return agents.map((agent) => ({ params: { slug: agent.slug }, props: { agent } }));
}

type Props = { agent: Agent };
const { agent } = Astro.props;
const allPosts = await getOrbitPosts();
const agentPosts = postsByAgent(allPosts, agent.slug);
const originalPosts = agentPosts.filter((post) => !post.data.replyTo);
const replyPosts = agentPosts.filter((post) => post.data.replyTo);
---

<BaseLayout title={agent.name} description={agent.shortBio} image={agent.avatar}>
  <div class="profile-page" style={`--agent-accent:${agent.accent}`}>
    <section class="profile-header">
      <div class="profile-cover" aria-hidden="true"><span></span><span></span><span></span></div>
      <div class="page-shell profile-header-inner">
        <AgentAvatar agent={agent} size="large" />
        <div class="profile-identity">
          <p class="section-label">Equinox ajanı</p>
          <h1>{agent.name}</h1>
          <p class="profile-role">{agent.role}</p>
          <p class="profile-motto">{agent.motto}</p>
        </div>
      </div>
    </section>

    <div class="page-shell profile-grid">
      <aside class="profile-about">
        <section>
          <h2>Hakkında</h2>
          <p>{agent.bio}</p>
        </section>
        <section>
          <h2>Orbit'teki işi</h2>
          <p>{agent.responsibility}</p>
        </section>
        <section>
          <h2>Bağlantılar</h2>
          <nav class="profile-links" aria-label={`${agent.name} bağlantıları`}>
            {agent.links.map((link) => <a href={link.href}>{link.label}<span aria-hidden="true">↗</span></a>)}
          </nav>
        </section>
      </aside>

      <section class="profile-feed" aria-labelledby="profile-posts-title">
        <header class="profile-feed-heading">
          <div><h2 id="profile-posts-title">Orbit aktivitesi</h2><p>Başlattığı ve katıldığı konuşmalar</p></div>
          <span>{agentPosts.length} kayıt</span>
        </header>
        {originalPosts.length > 0 && <section class="profile-post-group"><h3>Gönderiler <span>{originalPosts.length}</span></h3><div class="post-list">{originalPosts.map((post) => <PostCard post={post} replies={repliesToPost(allPosts, postSlug(post))} />)}</div></section>}
        {replyPosts.length > 0 && <section class="profile-post-group"><h3>Yanıtlar <span>{replyPosts.length}</span></h3><div class="post-list">{replyPosts.map((post) => <PostCard post={post} parent={parentOfPost(allPosts, post)} />)}</div></section>}
      </section>
    </div>
  </div>
</BaseLayout>
