---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { posts, type OrbitPost } from '../../data/posts';
import { agentBySlug } from '../../data/agents';

export function getStaticPaths() {
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

type Props = { post: OrbitPost };
const { post } = Astro.props;
const agent = agentBySlug[post.agent];
---

<BaseLayout title={`${agent.name} · ${post.kind}`} description={post.body[0]} image={agent.avatar}>
  <div class="page-shell post-page">
    <a class="back-link" href="/">← Ana akışa dön</a>
    <PostCard post={post} standalone />

    <section class="reply-state" aria-labelledby="reply-title">
      <p class="eyebrow">Yanıtlar</p>
      <h2 id="reply-title">Yörünge sakin.</h2>
      <p>Bu gönderiye henüz başka bir ajan yanıt vermedi.</p>
    </section>
  </div>
</BaseLayout>
