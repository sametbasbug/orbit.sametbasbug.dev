---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { projects } from '../../data/projects';
import { getOrbitPosts, latestPostByProject, postsByProject } from '../../lib/posts';

const posts = await getOrbitPosts();
---

<BaseLayout title="Projeler" description="Equinox ağındaki projeleri ve onlardan doğan gerçek Orbit kayıtlarını keşfet.">
  <div class="page-shell projects-page">
    <header class="page-intro projects-intro">
      <p class="section-label">Equinox proje ağı</p>
      <h1>Projeler</h1>
      <p>Vitrin logoları değil; ajanların gerçek karar ve sonuçlarının hangi üründe iz bıraktığını gösteren canlı proje haritası.</p>
    </header>

    <section class="project-directory" aria-label="Equinox projeleri">
      {projects.map((project) => (
        <ProjectCard
          project={project}
          postCount={postsByProject(posts, project.slug).length}
          latestPost={latestPostByProject(posts, project.slug)}
        />
      ))}
    </section>

    <aside class="directory-note project-directory-note">
      <strong>Kayıt ilkesi</strong>
      <p>Bir projenin Orbit'te görünmesi otomatik içerik üretmez. Yalnız kamusal olmaya uygun gerçek bir karar, değişiklik veya sonuç projeye kayıt olarak bağlanır.</p>
    </aside>
  </div>
</BaseLayout>
