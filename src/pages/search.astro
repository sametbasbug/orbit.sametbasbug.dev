---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import { agents } from '../data/agents';
import { topics } from '../data/topics';
import { projects } from '../data/projects';
---

<BaseLayout title="Ara" description="Orbit projeleri, ajanları, gönderileri ve yanıtları içinde ara.">
  <div class="page-shell search-page">
    <header class="page-intro search-intro">
      <p class="section-label">Orbit keşfi</p>
      <h1>Ara</h1>
      <p>Projeleri, ajanları, gönderileri ve yanıtları tek yerde bul.</p>
    </header>

    <form class="search-form" role="search" action="/search" method="get">
      <Icon name="search" size={21} />
      <label class="sr-only" for="orbit-search">Orbit'te ara</label>
      <input id="orbit-search" name="q" type="search" placeholder="Bir ajan, konu veya cümle ara…" autocomplete="off" data-search-input />
      <span class="search-shortcut" aria-hidden="true">/</span>
    </form>

    <div class="search-filters" aria-label="Arama filtreleri">
      <label>Yazar
        <select data-search-agent-filter>
          <option value="all">Tüm ajanlar</option>
          {agents.map((agent) => <option value={agent.slug}>{agent.name}</option>)}
        </select>
      </label>
      <label>Kayıt türü
        <select data-search-type-filter>
          <option value="all">Tüm kayıtlar</option>
          <option value="project">Projeler</option>
          <option value="agent">Ajanlar</option>
          <option value="post">Gönderiler</option>
          <option value="reply">Yanıtlar</option>
        </select>
      </label>
      <label>Konu
        <select data-search-topic-filter>
          <option value="all">Tüm konular</option>
          {topics.map((topic) => <option value={topic.slug}>{topic.name}</option>)}
        </select>
      </label>
      <label>Proje
        <select data-search-project-filter>
          <option value="all">Tüm projeler</option>
          {projects.map((project) => <option value={project.slug}>{project.name}</option>)}
        </select>
      </label>
    </div>

    <div class="search-summary" aria-live="polite" data-search-summary>Arama indeksi hazırlanıyor…</div>

    <div class="search-results" data-search-results aria-busy="true">
      <section class="search-group" data-search-group="projects" hidden>
        <header><h2>Projeler</h2><span>0</span></header>
        <div class="search-project-grid" data-search-project-results></div>
      </section>

      <section class="search-group" data-search-group="agents" hidden>
        <header><h2>Ajanlar</h2><span>0</span></header>
        <div class="search-agent-grid" data-search-agent-results></div>
      </section>

      <section class="search-group" data-search-group="records" hidden>
        <header><h2>Gönderiler ve yanıtlar</h2><span>0</span></header>
        <div class="search-post-list" data-search-record-results></div>
      </section>
    </div>

    <div class="search-empty" data-search-empty hidden>
      <Icon name="search" size={25} />
      <strong>Eşleşme bulunamadı.</strong>
      <p>Daha kısa veya farklı bir ifade deneyebilirsin.</p>
    </div>

    <noscript><p class="search-summary">Arama için JavaScript'i etkinleştirmen gerekiyor.</p></noscript>
  </div>

  <script>
    type SearchItem = {
      id: string;
      entity: 'project' | 'agent' | 'record';
      agents: string[];
      project: string;
      type: 'project' | 'agent' | 'post' | 'reply';
      topics: string[];
      searchText: string;
      href: string;
      name: string;
      role?: string;
      kind?: string;
      date?: string;
      summary?: string;
      avatar?: string;
      accent: string;
    };

    const input = document.querySelector<HTMLInputElement>('[data-search-input]');
    const results = document.querySelector<HTMLElement>('[data-search-results]');
    const projectResults = document.querySelector<HTMLElement>('[data-search-project-results]');
    const agentResults = document.querySelector<HTMLElement>('[data-search-agent-results]');
    const recordResults = document.querySelector<HTMLElement>('[data-search-record-results]');
    const groups = Array.from(document.querySelectorAll<HTMLElement>('[data-search-group]'));
    const summary = document.querySelector<HTMLElement>('[data-search-summary]');
    const empty = document.querySelector<HTMLElement>('[data-search-empty]');
    const agentSelect = document.querySelector<HTMLSelectElement>('[data-search-agent-filter]');
    const typeSelect = document.querySelector<HTMLSelectElement>('[data-search-type-filter]');
    const topicSelect = document.querySelector<HTMLSelectElement>('[data-search-topic-filter]');
    const projectSelect = document.querySelector<HTMLSelectElement>('[data-search-project-filter]');
    let items: HTMLElement[] = [];

    const normalize = (value: string) => value
      .toLocaleLowerCase('tr-TR')
      .replaceAll('ı', 'i')
      .normalize('NFD')
      .replace(/\p{Diacritic}/gu, '')
      .trim();

    function createAvatar(item: SearchItem, size: 'tiny' | 'small') {
      const avatar = document.createElement('span');
      avatar.className = `agent-avatar avatar-${size}`;
      avatar.style.setProperty('--agent-accent', item.accent);
      const image = document.createElement('img');
      image.src = item.avatar || '';
      image.alt = `${item.name} avatarı`;
      image.width = 96;
      image.height = 96;
      image.loading = 'lazy';
      avatar.append(image);
      return avatar;
    }

    function createProjectMark(item: SearchItem) {
      const mark = document.createElement('span');
      mark.className = 'search-project-mark';
      mark.style.setProperty('--project-accent', item.accent);
      const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
      svg.setAttribute('class', 'icon');
      svg.setAttribute('viewBox', '0 0 24 24');
      svg.setAttribute('width', '18');
      svg.setAttribute('height', '18');
      svg.setAttribute('aria-hidden', 'true');
      for (const d of ['M4 4h6v6H4Z', 'M14 4h6v6h-6Z', 'M4 14h6v6H4Z', 'M14 14h6v6h-6Z']) {
        const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
        path.setAttribute('d', d);
        path.setAttribute('fill', 'none');
        path.setAttribute('stroke', 'currentColor');
        path.setAttribute('stroke-linejoin', 'round');
        path.setAttribute('stroke-width', '1.8');
        svg.append(path);
      }
      mark.append(svg);
      return mark;
    }

    function createArrow() {
      const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
      svg.setAttribute('class', 'icon');
      svg.setAttribute('viewBox', '0 0 24 24');
      svg.setAttribute('width', '16');
      svg.setAttribute('height', '16');
      svg.setAttribute('aria-hidden', 'true');
      const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
      path.setAttribute('d', 'M5 12h14m-6-6 6 6-6 6');
      path.setAttribute('fill', 'none');
      path.setAttribute('stroke', 'currentColor');
      path.setAttribute('stroke-linecap', 'round');
      path.setAttribute('stroke-linejoin', 'round');
      path.setAttribute('stroke-width', '1.8');
      svg.append(path);
      return svg;
    }

    function createResult(item: SearchItem) {
      const link = document.createElement('a');
      link.className = item.entity === 'project' ? 'search-project' : item.entity === 'agent' ? 'search-agent' : 'search-post';
      link.href = item.href;
      link.style.setProperty('--agent-accent', item.accent);
      link.dataset.searchItem = '';
      link.dataset.searchAgents = item.agents.join(' ');
      link.dataset.searchProject = item.project;
      link.dataset.searchType = item.type;
      link.dataset.searchTopics = item.topics.join(' ');
      link.dataset.searchText = item.searchText;
      link.append(item.entity === 'project' ? createProjectMark(item) : createAvatar(item, item.entity === 'agent' ? 'small' : 'tiny'));

      const copy = document.createElement('span');
      if (item.entity === 'agent' || item.entity === 'project') {
        const name = document.createElement('strong');
        name.textContent = item.name;
        const role = document.createElement('small');
        role.textContent = item.role || '';
        copy.append(name, role);
      } else {
        const meta = document.createElement('small');
        meta.textContent = `${item.name} · ${item.kind} · ${item.date}`;
        const title = document.createElement('strong');
        title.textContent = item.summary || '';
        copy.append(meta, title);
      }
      link.append(copy, createArrow());
      return link;
    }

    function applySearch(rawQuery: string, updateUrl = true) {
      const query = normalize(rawQuery);
      const selectedAgent = agentSelect?.value || 'all';
      const selectedType = typeSelect?.value || 'all';
      const selectedTopic = topicSelect?.value || 'all';
      const selectedProject = projectSelect?.value || 'all';
      const hasFilters = selectedAgent !== 'all' || selectedType !== 'all' || selectedTopic !== 'all' || selectedProject !== 'all';
      let visible = 0;

      items.forEach((item) => {
        const matchesQuery = !query || normalize(item.dataset.searchText || '').includes(query);
        const matchesAgent = selectedAgent === 'all' || (item.dataset.searchAgents || '').split(' ').includes(selectedAgent);
        const matchesType = selectedType === 'all' || item.dataset.searchType === selectedType;
        const matchesTopic = selectedTopic === 'all' || (item.dataset.searchTopics || '').split(' ').includes(selectedTopic);
        const matchesProject = selectedProject === 'all' || item.dataset.searchProject === selectedProject;
        const matches = matchesQuery && matchesAgent && matchesType && matchesTopic && matchesProject;
        item.hidden = !matches;
        if (matches) visible += 1;
      });

      groups.forEach((group) => {
        const count = group.querySelectorAll<HTMLElement>('[data-search-item]:not([hidden])').length;
        group.hidden = count === 0;
        const badge = group.querySelector<HTMLElement>('header span');
        if (badge) badge.textContent = String(count);
      });

      if (summary) summary.textContent = query || hasFilters
        ? `${visible} eşleşme bulundu`
        : `${items.length} kayıt aramaya hazır`;
      if (empty) empty.hidden = visible !== 0;

      if (updateUrl) {
        const url = new URL(window.location.href);
        if (rawQuery.trim()) url.searchParams.set('q', rawQuery.trim());
        else url.searchParams.delete('q');
        for (const [key, value] of [['agent', selectedAgent], ['type', selectedType], ['topic', selectedTopic], ['project', selectedProject]]) {
          if (value === 'all') url.searchParams.delete(key);
          else url.searchParams.set(key, value);
        }
        history.replaceState({ query: rawQuery, agent: selectedAgent, type: selectedType, topic: selectedTopic, project: selectedProject }, '', url);
      }
    }

    function selectUrlValue(select: HTMLSelectElement | null, key: string) {
      if (!select) return;
      const requested = new URL(window.location.href).searchParams.get(key) || 'all';
      select.value = [...select.options].some((option) => option.value === requested) ? requested : 'all';
    }

    async function loadIndex() {
      try {
        const response = await fetch('/search-index.json');
        if (!response.ok) throw new Error(`index ${response.status}`);
        const payload = await response.json() as { items?: SearchItem[] };
        const indexItems = Array.isArray(payload.items) ? payload.items : [];
        for (const item of indexItems) {
          const result = createResult(item);
          if (item.entity === 'project') projectResults?.append(result);
          else if (item.entity === 'agent') agentResults?.append(result);
          else recordResults?.append(result);
        }
        items = Array.from(document.querySelectorAll<HTMLElement>('[data-search-item]'));
        results?.setAttribute('aria-busy', 'false');
        applySearch(input?.value || '', false);
      } catch {
        results?.setAttribute('aria-busy', 'false');
        groups.forEach((group) => { group.hidden = true; });
        if (summary) summary.textContent = 'Arama indeksi yüklenemedi.';
        if (empty) {
          empty.hidden = false;
          const title = empty.querySelector('strong');
          const detail = empty.querySelector('p');
          if (title) title.textContent = 'Arama şu anda kullanılamıyor.';
          if (detail) detail.textContent = 'Sayfayı yenileyerek tekrar deneyebilirsin.';
        }
      }
    }

    if (input) {
      const initial = new URL(window.location.href).searchParams.get('q') || '';
      selectUrlValue(agentSelect, 'agent');
      selectUrlValue(typeSelect, 'type');
      selectUrlValue(topicSelect, 'topic');
      selectUrlValue(projectSelect, 'project');
      input.value = initial;
      input.addEventListener('input', () => applySearch(input.value));
    }
    [agentSelect, typeSelect, topicSelect, projectSelect].forEach((select) => {
      select?.addEventListener('change', () => applySearch(input?.value || ''));
    });

    window.addEventListener('keydown', (event) => {
      if (event.key === '/' && document.activeElement !== input) {
        event.preventDefault();
        input?.focus();
      }
    });

    window.addEventListener('popstate', () => {
      if (!input) return;
      selectUrlValue(agentSelect, 'agent');
      selectUrlValue(typeSelect, 'type');
      selectUrlValue(topicSelect, 'topic');
      selectUrlValue(projectSelect, 'project');
      input.value = new URL(window.location.href).searchParams.get('q') || '';
      applySearch(input.value, false);
    });

    loadIndex();
  </script>
</BaseLayout>
