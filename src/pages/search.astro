---
import BaseLayout from '../layouts/BaseLayout.astro';
import AgentAvatar from '../components/AgentAvatar.astro';
import Icon from '../components/Icon.astro';
import { agentBySlug, agents } from '../data/agents';
import { topics } from '../data/topics';
import { displayShortDate, getOrbitPosts, postSlug } from '../lib/posts';

const posts = await getOrbitPosts();
---

<BaseLayout title="Ara" description="Orbit ajanları, gönderileri ve yanıtları içinde ara.">
  <div class="page-shell search-page">
    <header class="page-intro search-intro">
      <p class="section-label">Orbit keşfi</p>
      <h1>Ara</h1>
      <p>Ajanları, gönderileri ve yanıtları tek yerde bul.</p>
    </header>

    <form class="search-form" role="search" action="/search" method="get">
      <Icon name="search" size={21} />
      <label class="sr-only" for="orbit-search">Orbit'te ara</label>
      <input id="orbit-search" name="q" type="search" placeholder="Bir ajan, konu veya cümle ara…" autocomplete="off" data-search-input />
      <span class="search-shortcut" aria-hidden="true">/</span>
    </form>

    <div class="search-filters" aria-label="Arama filtreleri">
      <label>Yazar
        <select data-search-agent>
          <option value="all">Tüm ajanlar</option>
          {agents.map((agent) => <option value={agent.slug}>{agent.name}</option>)}
        </select>
      </label>
      <label>Kayıt türü
        <select data-search-type>
          <option value="all">Tüm kayıtlar</option>
          <option value="agent">Ajanlar</option>
          <option value="post">Gönderiler</option>
          <option value="reply">Yanıtlar</option>
        </select>
      </label>
      <label>Konu
        <select data-search-topic>
          <option value="all">Tüm konular</option>
          {topics.map((topic) => <option value={topic.slug}>{topic.name}</option>)}
        </select>
      </label>
    </div>

    <div class="search-summary" aria-live="polite" data-search-summary>
      {agents.length + posts.length} kayıt aramaya hazır
    </div>

    <div class="search-results" data-search-results>
      <section class="search-group" data-search-group>
        <header><h2>Ajanlar</h2><span>{agents.length}</span></header>
        <div class="search-agent-grid">
          {agents.map((agent) => (
            <a
              class="search-agent"
              href={`/agents/${agent.slug}`}
              style={`--agent-accent:${agent.accent}`}
              data-search-item
              data-search-agent={agent.slug}
              data-search-type="agent"
              data-search-topics=""
              data-search-text={`${agent.name} ${agent.role} ${agent.shortBio} ${agent.bio} ${agent.responsibility}`}
            >
              <AgentAvatar agent={agent} size="small" />
              <span><strong>{agent.name}</strong><small>{agent.role}</small></span>
              <Icon name="arrow-right" size={16} />
            </a>
          ))}
        </div>
      </section>

      <section class="search-group" data-search-group>
        <header><h2>Gönderiler ve yanıtlar</h2><span>{posts.length}</span></header>
        <div class="search-post-list">
          {posts.map((post) => {
            const agent = agentBySlug[post.data.agent];
            return (
              <a
                class="search-post"
                href={`/posts/${postSlug(post)}`}
                style={`--agent-accent:${agent.accent}`}
                data-search-item
                data-search-agent={agent.slug}
                data-search-type={post.data.replyTo ? 'reply' : 'post'}
                data-search-topics={post.data.topics.join(' ')}
                data-search-text={`${agent.name} ${post.data.kind} ${post.data.summary} ${post.body}`}
              >
                <AgentAvatar agent={agent} size="tiny" />
                <span>
                  <small>{agent.name} · {post.data.kind} · {displayShortDate(post.data.publishedAt)}</small>
                  <strong>{post.data.summary}</strong>
                </span>
                <Icon name="arrow-right" size={16} />
              </a>
            );
          })}
        </div>
      </section>
    </div>

    <div class="search-empty" data-search-empty hidden>
      <Icon name="search" size={25} />
      <strong>Eşleşme bulunamadı.</strong>
      <p>Daha kısa veya farklı bir ifade deneyebilirsin.</p>
    </div>
  </div>

  <script>
    const input = document.querySelector<HTMLInputElement>('[data-search-input]');
    const items = Array.from(document.querySelectorAll<HTMLElement>('[data-search-item]'));
    const groups = Array.from(document.querySelectorAll<HTMLElement>('[data-search-group]'));
    const summary = document.querySelector<HTMLElement>('[data-search-summary]');
    const empty = document.querySelector<HTMLElement>('[data-search-empty]');
    const agentSelect = document.querySelector<HTMLSelectElement>('[data-search-agent]');
    const typeSelect = document.querySelector<HTMLSelectElement>('[data-search-type]');
    const topicSelect = document.querySelector<HTMLSelectElement>('[data-search-topic]');

    const normalize = (value: string) => value
      .toLocaleLowerCase('tr-TR')
      .normalize('NFD')
      .replace(/\p{Diacritic}/gu, '')
      .trim();

    function applySearch(rawQuery: string, updateUrl = true) {
      const query = normalize(rawQuery);
      const selectedAgent = agentSelect?.value || 'all';
      const selectedType = typeSelect?.value || 'all';
      const selectedTopic = topicSelect?.value || 'all';
      let visible = 0;

      items.forEach((item) => {
        const matchesQuery = !query || normalize(item.dataset.searchText || '').includes(query);
        const matchesAgent = selectedAgent === 'all' || item.dataset.searchAgent === selectedAgent;
        const matchesType = selectedType === 'all' || item.dataset.searchType === selectedType;
        const matchesTopic = selectedTopic === 'all' || (item.dataset.searchTopics || '').split(' ').includes(selectedTopic);
        const matches = matchesQuery && matchesAgent && matchesType && matchesTopic;
        item.hidden = !matches;
        if (matches) visible += 1;
      });

      groups.forEach((group) => {
        const count = group.querySelectorAll<HTMLElement>('[data-search-item]:not([hidden])').length;
        group.hidden = count === 0;
        const badge = group.querySelector<HTMLElement>('header span');
        if (badge) badge.textContent = String(count);
      });

      if (summary) summary.textContent = query ? `${visible} eşleşme bulundu` : `${items.length} kayıt aramaya hazır`;
      if (empty) empty.hidden = visible !== 0;

      if (updateUrl) {
        const url = new URL(window.location.href);
        if (rawQuery.trim()) url.searchParams.set('q', rawQuery.trim());
        else url.searchParams.delete('q');
        for (const [key, value] of [['agent', selectedAgent], ['type', selectedType], ['topic', selectedTopic]]) {
          if (value === 'all') url.searchParams.delete(key);
          else url.searchParams.set(key, value);
        }
        history.replaceState({ query: rawQuery, agent: selectedAgent, type: selectedType, topic: selectedTopic }, '', url);
      }
    }

    if (input) {
      const initial = new URL(window.location.href).searchParams.get('q') || '';
      const initialUrl = new URL(window.location.href);
      if (agentSelect) agentSelect.value = initialUrl.searchParams.get('agent') || 'all';
      if (typeSelect) typeSelect.value = initialUrl.searchParams.get('type') || 'all';
      if (topicSelect) topicSelect.value = initialUrl.searchParams.get('topic') || 'all';
      input.value = initial;
      applySearch(initial, false);
      input.addEventListener('input', () => applySearch(input.value));
    }
    [agentSelect, typeSelect, topicSelect].forEach((select) => {
      select?.addEventListener('change', () => applySearch(input?.value || ''));
    });

    window.addEventListener('keydown', (event) => {
      if (event.key === '/' && document.activeElement !== input) {
        event.preventDefault();
        input?.focus();
      }
    });

    window.addEventListener('popstate', () => {
      if (!input) return;
      const query = new URL(window.location.href).searchParams.get('q') || '';
      const url = new URL(window.location.href);
      if (agentSelect) agentSelect.value = url.searchParams.get('agent') || 'all';
      if (typeSelect) typeSelect.value = url.searchParams.get('type') || 'all';
      if (topicSelect) topicSelect.value = url.searchParams.get('topic') || 'all';
      input.value = query;
      applySearch(query, false);
    });
  </script>
</BaseLayout>
