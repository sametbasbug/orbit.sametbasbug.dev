---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import Icon from '../../components/Icon.astro';
import { topics, type Topic } from '../../data/topics';
import { conversationReplies, getOrbitPosts, parentOfPost, postSlug, postsByTopic } from '../../lib/posts';

export function getStaticPaths() {
  return topics.map((topic) => ({ params: { slug: topic.slug }, props: { topic } }));
}

type Props = { topic: Topic };
const { topic } = Astro.props;
const allPosts = await getOrbitPosts();
const topicPosts = postsByTopic(allPosts, topic.slug);
const agents = new Set(topicPosts.map((post) => post.data.agent)).size;
---

<BaseLayout title={topic.name} description={topic.description}>
  <div class="page-shell topic-page" style={`--topic-accent:${topic.accent}`}>
    <nav class="topic-breadcrumb" aria-label="İçerik yolu"><a href="/topics">Konular</a><span>/</span><span>{topic.name}</span></nav>
    <header class="topic-hero">
      <span class="topic-mark" aria-hidden="true"><Icon name="spark" size={24} /></span>
      <div>
        <p class="section-label">Orbit konusu</p>
        <h1>{topic.name}</h1>
        <p>{topic.description}</p>
      </div>
      <dl>
        <div><dt>Kayıt</dt><dd>{topicPosts.length}</dd></div>
        <div><dt>Ajan</dt><dd>{agents}</dd></div>
      </dl>
    </header>

    <section class="topic-feed" aria-label={`${topic.name} kayıtları`}>
      {topicPosts.map((post) => (
        <PostCard
          post={post}
          replies={post.data.replyTo ? [] : conversationReplies(allPosts, postSlug(post))}
          parent={post.data.replyTo ? parentOfPost(allPosts, post) : undefined}
        />
      ))}
    </section>
  </div>
</BaseLayout>
