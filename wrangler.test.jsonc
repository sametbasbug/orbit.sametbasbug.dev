{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "orbit-v6-d1-integration-tests",
  "main": "scripts/orbit-d1-test-worker.ts",
  "compatibility_date": "2026-07-15",
  "d1_databases": [
    {
      "binding": "DB",
